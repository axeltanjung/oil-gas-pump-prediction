# ============================================================
# Oil & Gas Pump Failure Prediction System - Environment config
# Copy to `.env` and adjust as needed.
# ============================================================

# ---- Paths ----
DATA_DIR=./data
MODEL_DIR=./models
SQLITE_PATH=./data/pumps.db

# ---- Data generation ----
N_PUMPS=25
N_HOURS=4500
RANDOM_SEED=42

# ---- ML / training ----
FAILURE_HORIZON_DAYS=7
LSTM_SEQUENCE_LEN=48
LSTM_EPOCHS=15

# ---- MLflow ----
MLFLOW_TRACKING_URI=./mlflow/mlruns
MLFLOW_EXPERIMENT=oil_gas_pump_prediction

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ---- Frontend ----
VITE_API_BASE_URL=http://localhost:8000
